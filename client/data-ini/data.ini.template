; ============================================================
; RO Client data.ini
; 方案A: 2021-11-03 Ragexe + 匹配版本 data.grf
; ============================================================
;
; 优先级规则：编号小的 GRF 覆盖编号大的
; - custom.grf 放第一位，用于中文资源和自定义覆盖
; - rdata.grf 放第二位
; - data.grf 放最后，作为基础数据
;
; 使用方法：
; 1. 将此文件复制到客户端根目录，重命名为 data.ini
; 2. 确保 custom.grf / rdata.grf / data.grf 都在同一目录
;
[Data]
0 = custom.grf
1 = rdata.grf
2 = data.grf
